{
  "name": "amazon-ads-mcp",
  "version": "0.1.0",
  "description": "MCP server for Amazon Ads API (Sponsored Products, Brands, Display)",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "amazon-ads-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "amazon-mcp-common": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.14.0",
    "dotenv": "^16.4.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.5.0",
    "typescript-eslint": "^8.0.0",
    "eslint-config-prettier": "^9.1.0",
    "@eslint/js": "^9.5.0",
    "prettier": "^3.3.0",
    "tsx": "^4.16.0"
  },
  "files": ["dist"],
  "engines": {
    "node": ">=18.0.0"
  }
}
