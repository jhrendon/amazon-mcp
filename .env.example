# Amazon LWA Credentials (shared by both Seller Central and Ads API)
# Get these from https://developer.amazon.com/
LWA_CLIENT_ID=amzn1.application-oa2-client.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LWA_CLIENT_SECRET=amzn1.oa2-cs.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Seller Central (amazon-seller-mcp)
SELLER_REFRESH_TOKEN=Atzr|.
SELLER_ID=Axxxxxxxxxxxxxxx
MARKETPLACE_ID=ATVPDKIKX0DER

# Amazon Ads API (amazon-ads-mcp)
# Refresh token authorized for advertising::campaign_management scope
ADS_REFRESH_TOKEN=Atzr|.
ADS_PROFILE_ID=xxxxxxxxxxxxx
ADS_API_REGION=na

# Optional: Override endpoints (for sandbox testing)
# SELLER_API_ENDPOINT=https://sellingpartnerapi-na.amazon.com
# ADS_API_ENDPOINT=https://advertising-api-test.amazon.com
